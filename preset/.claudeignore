# Sync state (machine-managed, not useful in context)
.ccanvil/ccanvil.lock

# Local config (read via scripts, not raw file reads)
.claude/ccanvil.local.json

# Claude Code worktrees (session-specific, not useful in context)
.claude/worktrees/
