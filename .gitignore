# OS
.DS_Store

# Dependencies
node_modules/

# Build output
dist/
generated/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (per-user, not shared)
.claude/settings.local.json
.claude/ccanvil.local.json
.claude/local/

# Claude Code worktrees (per-session, not shared)
.claude/worktrees/

# Claude Code /loop and /schedule artifacts (BTS-168)
# Session-local; don't survive /compact reliably and aren't committable state.
# ccanvil does not provide a durable cron substrate; recurring work that needs
# to survive sessions belongs in Linear / the idea queue.
.claude/scheduled_tasks*

# Sync state — tracked in git for provenance.
# Listed in .claudeignore so Claude uses the script to access them, not raw reads.

# Machine-local operational state — per-user, not shared
# (registry maps downstream node UUIDs → paths on this machine;
#  events.log is the append-only audit trail for register/broadcast)
.ccanvil/registry.json
.ccanvil/events.log
docs/ideas.md
.ccanvil/ideas-pending.log
.ccanvil/ideas.log
.ccanvil/state/
